{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(*)",
      "Bash(npx tsc --noEmit *)",
      "Bash(npm list *)",
      "Bash(pnpm lint)",
      "Bash(pnpm typecheck)",
      "Bash(fuser *)",
      "Write(*)",
      "Edit(*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/)",
      "Bash(rm -rf /home*)",
      "Bash(rm -rf /usr*)",
      "Bash(rm -rf /etc*)",
      "Bash(rm -rf /var*)",
      "Bash(sudo rm -rf *)",
      "Bash(sudo rm -f /etc*)",
      "Bash(sudo rm -f /usr*)",
      "Bash(npm publish)",
      "Bash(npm publish *)",
      "Bash(twine upload *)",
      "Bash(cargo publish)",
      "Bash(cargo publish *)",
      "Bash(gem push *)",
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(git push:*)",
      "Bash(aws ec2 run-instances *)",
      "Bash(aws rds create-db-instance *)",
      "Bash(aws lambda create-function *)",
      "Bash(aws ecs run-task *)",
      "Bash(aws eks create-cluster *)",
      "Bash(aws s3api create-bucket *)",
      "Bash(gcloud compute instances create *)",
      "Bash(gcloud container clusters create *)",
      "Bash(gcloud sql instances create *)",
      "Bash(az vm create *)",
      "Bash(az aks create *)",
      "Bash(supabase db reset)",
      "Bash(supabase db reset *)",
      "Bash(curl * | bash)",
      "Bash(curl * | bash *)",
      "Bash(curl * | sh)",
      "Bash(curl * | sh *)",
      "Bash(wget * | bash)",
      "Bash(wget * | bash *)",
      "Bash(wget * | sh)",
      "Bash(wget * -O- | bash)",
      "Bash(watch * claude *)",
      "Bash(while * claude *)",
      "Bash(for * claude *)",
      "Write(/etc/*)",
      "Write(/usr/*)",
      "Write(/boot/*)",
      "Write(~/.ssh/*)",
      "Edit(/etc/*)",
      "Edit(/usr/*)",
      "Edit(/boot/*)",
      "Edit(~/.ssh/*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd=$(jq -r '.tool_input.command // \"\"'); if printf '%s' \"$cmd\" | grep -Eq '(^|[^[:alnum:]_./-])git(([[:space:]]+-C[[:space:]]+[^[:space:]]+)|([[:space:]]+-c[[:space:]]+[^[:space:]]+)|([[:space:]]+--?[^[:space:]]+))*[[:space:]]+push([[:space:]]|$)'; then printf '%s' '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\"git push prohibido: todos los push son manuales (politica del usuario). Hazlo tu mismo.\"}}'; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify-stop.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify-attention.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "theme": "dark",
  "preferredNotifChannel": "ghostty",
  "agentPushNotifEnabled": true
}
